# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code（默认全排除，例外子目录见下）
.claude/*
# 例外：skills/ 入库用于跨设备/团队复用 Claude Code skill 定义（G3）
!.claude/skills/
# 例外：memory-snapshot 跟踪入 git 用于跨设备同步（A6）
!.claude/memory-snapshot/
# 例外：settings.json 含 SubagentStop / Stop hook 注册，必须跟 git
!.claude/settings.json
# 例外：项目级 subagent 定义（kb-auditor / plan-executor / idea-extractor）
!.claude/agents/

# Aone Copilot (plans / tasks 等本地状态文件，不入库)
.aone_copilot/

# Temp files
*.tmp
*.bak
.worktrees/

# 构建产物（由 build-index.js 生成，不入库）
manifest.json
# 构建产物（由 build-timeline.js 生成，不入库）
timeline.json
